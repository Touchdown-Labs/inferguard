# Required
TARGET_ENDPOINT=http://localhost:8000

# Upstash Redis (REST API)
UPSTASH_REDIS_URL=https://YOUR_REDIS.upstash.io
UPSTASH_REDIS_TOKEN=AX...your_token

# Upstash Vector (REST API)
UPSTASH_VECTOR_URL=https://YOUR_VECTOR.upstash.io
UPSTASH_VECTOR_TOKEN=AX...your_token

# Diagnosis provider (GMI Cloud)
GMI_BASE_URL=https://api.gmi-serving.com/v1
GMI_API_KEY=gmi-...             # Primary diagnosis credential
GMI_MODEL=openai/gpt-oss-120b

# Legacy compatibility aliases (read only if GMI_* is unset)
# LLM_BASE_URL=https://api.gmi-serving.com/v1
# LLM_API_KEY=gmi-...
# LLM_MODEL=openai/gpt-oss-120b

# Thresholds
KV_ALERT_THRESHOLD=0.85
TTFT_ALERT_MULTIPLIER=2.0
POLL_INTERVAL_SECONDS=30
